{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "blux-ca Expected Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "contract_version",
    "fixture_id",
    "engine",
    "request",
    "mode",
    "status",
    "outcome",
    "checks"
  ],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "contract_version": {"type": "string", "minLength": 1},
    "fixture_id": {"type": "string", "minLength": 1},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "line", "dataset_version"],
      "properties": {
        "name": {"type": "string", "const": "blux-ca"},
        "line": {"type": "string", "minLength": 1},
        "dataset_version": {"type": "string", "minLength": 1}
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_pack_id", "policy_pack_version", "profile_id", "profile_version", "device"],
      "properties": {
        "policy_pack_id": {"type": "string", "minLength": 1},
        "policy_pack_version": {"type": ["string", "null"]},
        "profile_id": {"type": ["string", "null"]},
        "profile_version": {"type": ["string", "null"]},
        "device": {"type": ["string", "null"]}
      }
    },
    "mode": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "fail", "infeasible"]},
    "outcome": {"type": "string", "enum": ["pass", "fail", "infeasible"]},
    "policy_pack": {"type": "string"},
    "tier": {"type": "string"},
    "validator_pack": {"type": "string"},
    "profile_id": {"type": "string"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "notes"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "fail", "infeasible"]},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
